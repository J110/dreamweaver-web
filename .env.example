# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production, set to your backend URL:
# NEXT_PUBLIC_API_URL=https://api.dreamweaver.app

# Analytics (PostHog product analytics + GA4 SEO/marketing)
# All NEXT_PUBLIC_* vars are inlined at build time — must exist before
# `npm run build`. On prod VM, canonical file is /opt/dreamweaver-web/.env.production.local
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA4_ID=
